#!/bin/bash

if [ -z "$1" ] || [ -z "$2" ]; then
  echo "Usage: mermaid <filename.mmd> <png|pdf|svg>"
  echo "Example: mermaid diagram.mmd png"
  exit 1
fi

# Create mermaid folder if it doesn't exist
mkdir -p ~/Documents/mermaid

docker run --rm \
  -v ~/Documents/mermaid:/data \
  mermaid \
  "$1" "$2"
